# Copy to .env and fill in what you need — every var is optional and the
# feature it powers degrades gracefully when unset.

# /resume.pdf proxies this Google Doc's PDF export (1h cache).
RESUME_GDOC_ID=

# "listening to now" card in the hobbies tab.
# Walkthrough: docs/spotify-setup.md
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Secret-page suggestion box (free key: https://resend.com/api-keys).
# With the default onboarding@resend.dev sender, CONTACT_TO must be the
# Resend account's own email; verify a domain + set CONTACT_FROM to change.
RESEND_API_KEY=
CONTACT_TO=

# Verified-domain sender for suggestion-box emails (defaults to
# onboarding@resend.dev when unset).
CONTACT_FROM=

# --- Docker / Caddy (docker-compose.yml) ---
# Local default is http://localhost (plain HTTP). On the VPS set your real
# domain (no scheme) so Caddy provisions HTTPS automatically:
# SITE_ADDRESS=yourdomain.com
SITE_ADDRESS=
